# Digital Alchemy — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local.

# ── Public site URL (no trailing slash) ──
NEXT_PUBLIC_SITE_URL=https://digitalalchemy.dev

# ── Supabase ──
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin ──
# ADMIN_EMAIL: the Google account that owns the OAuth tokens AND
# the only address allowed to log in at /admin.
# NEXT_PUBLIC_ADMIN_EMAIL: public mirror used by the login form's
# client-side pre-check. MUST match ADMIN_EMAIL exactly.
ADMIN_EMAIL=dbcreationsllc@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=dbcreationsllc@gmail.com

# Comma-separated list of addresses to CC on booking notifications.
# Leave blank to fall back to ADMIN_EMAIL. Whitespace around commas OK.
ADMIN_NOTIFICATION_EMAILS=desibaker54@gmail.com,dbcreationsllc@gmail.com

# ── Resend (newsletter + booking emails) ──
# Get an API key from https://resend.com/api-keys
# RESEND_FROM_EMAIL must be on a domain you've verified in Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=desi@digitalalchemy.dev

# ── Google Calendar (scheduling Phase 3) ──
# Create OAuth 2.0 credentials in Google Cloud Console, add both localhost
# and production redirect URIs, then paste the client id + secret here.
# Redirect URI is auto-derived from NEXT_PUBLIC_SITE_URL.
# See SETUP.md for the full walkthrough.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Cron auth (booking reminders + email autoresponder) ──
# Set any strong random string (e.g. `openssl rand -hex 32`).
# Scheduled callers send it as `Authorization: Bearer <CRON_SECRET>`
# to /api/scheduling/reminders and /api/email/sequence-runner.
CRON_SECRET=

# ── PostHog analytics (optional) ──
# From https://app.posthog.com → Project Settings → API keys.
# If unset, PostHogProvider becomes a no-op.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Upstash Redis (rate limiting — STRONGLY recommended in prod) ──
# Without these, every API rate limiter falls back to in-memory and
# resets on every Vercel cold start (basically useless against spam).
# Free tier covers tens of thousands of requests/day.
# 1. https://console.upstash.com → Create Database (Redis)
# 2. Copy "REST URL" and "REST Token" from the database page.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Telegram bot alerts (optional) ──
# Get a buzz on your phone when someone books, cancels, or 15 min before
# any booking starts.
# 1. In Telegram, message @BotFather → /newbot → save the token.
# 2. Open a chat with your new bot and send any message ("hi").
# 3. Run: npx tsx --env-file=.env.local scripts/telegram-setup.ts
#    It prints your chat ID. Paste it below.
# Leave both blank to disable Telegram alerts entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── PayPal payments (Phase 1: Bootcamp + Portfolio Building checkout) ──
# Full setup walkthrough lives in SETUP-paypal.md.
# Quick version:
#   1. developer.paypal.com → log in with the DB Creations PayPal Business account.
#   2. Apps & Credentials → Sandbox → Create App (name it "Digital Alchemy Dev").
#      Copy Client ID + Secret into PAYPAL_CLIENT_ID / PAYPAL_CLIENT_SECRET.
#      Mirror the Client ID into NEXT_PUBLIC_PAYPAL_CLIENT_ID (used by the
#      browser SDK to render Smart Buttons — safe to expose per PayPal docs).
#   3. Generate a path token: `openssl rand -hex 32` (or any 32+ char hex
#      string) → paste into PAYPAL_WEBHOOK_PATH_TOKEN. This makes the
#      webhook URL unguessable on top of PayPal's signature check.
#   4. In the same Sandbox app, scroll to Webhooks → Add Webhook with URL
#      https://<your-ngrok-or-prod>/api/payments/webhook/<the-path-token>
#      Subscribe to PAYMENT.CAPTURE.COMPLETED and PAYMENT.CAPTURE.REFUNDED.
#      Save → copy the Webhook ID into PAYPAL_WEBHOOK_ID.
#   5. Repeat under "Live" once sandbox is green. Flip PAYPAL_ENV to "live".
# Leave any of these blank to disable payments — /checkout/* will refuse
# with a 503 instead of crashing.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_WEBHOOK_ID=
PAYPAL_WEBHOOK_PATH_TOKEN=

# ── Sentry (optional — production error monitoring) ──
# Without a DSN, the SDK no-ops and nothing is reported. With a DSN,
# server errors + the global error boundary + payments security events
# all land in Sentry automatically.
# 1. sentry.io → Create Project → Next.js platform.
# 2. Copy the DSN it gives you into both vars below (one for server,
#    one for the browser bundle — Sentry recommends using the same DSN).
# 3. (Optional) For source map upload on Vercel deploys, also set
#    SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT (find them under
#    Settings → Auth Tokens, Settings → General, and the project name).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
