# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# local claude code / tooling
.claude/
.playwright-mcp/
.superpowers/

# ad-hoc local test scripts (one-off DB pokes, scratch queries).
# These often contain hardcoded tokens during debugging — never commit.
/test-*.ts
/test-*.js

# supabase CLI local cache
supabase/.temp/

# Captured webhook fixtures used by scripts/test-paypal-webhook-replay.ts.
# These hold real PayPal sandbox event payloads + signature headers and
# must never be committed.
scripts/test-webhook-fixture.json

# Sentry CLI / SDK build artifacts
.sentryclirc
